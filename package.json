{
  "name": "taskprio-repo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build::server": "turbo run build --filter=@repo/taskprio-types --filter=taskprio-api",
    "dev": "turbo run dev --parallel --force",
    "dev::types": "turbo run dev --filter=@repo/taskprio-types",
    "dev::server": "turbo run dev --filter=taskprio-api --filter=@repo/taskprio-types",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
