{
  "compilerOptions": {
    "target": "ESNext",
    "module": "node20",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "composite": true
  },
  "include": [
    "src/main",
    "src/preload",
    "src/lib",
    "vite.main.config.ts",
    "vite.preload.config.ts"
  ]
}